{
  "name": "@hyphae/access-control",
  "version": "0.0.0",
  "description": "Authentication and RBAC access control for hyphae",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test 'tests/**/*.test.ts'",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@hyphae/core": "workspace:*",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@hyphae/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "typescript": "^5.5.0"
  }
}
