{
  "name": "@hyphae/storage-memory",
  "version": "0.0.0",
  "description": "In-memory storage adapter for hyphae — for testing and ephemeral use",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test 'tests/**/*.test.ts'",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@hyphae/core": "workspace:*"
  },
  "devDependencies": {
    "@hyphae/config": "workspace:*",
    "typescript": "^5.5.0"
  }
}
